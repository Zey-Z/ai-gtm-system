    {
      "parameters": {
        "jsCode": "// ===== 1. 获取请求数据 =====\nconst body = $input.item.json.body || $input.item.json;\n\n// ===== 2. 输入校验 =====\nconst lead_text = body.lead_text;\nif (!lead_text || lead_text.trim() === '') {\n  // 返回校验失败标志（不再 throw Error）\n  return {\n    json: {\n      is_valid: false,\n      error: 'Missing required field: lead_text'\n    }\n  };\n}\n\n// ===== 3. 生成 run_id（链路追踪） =====\nconst run_id = $execution.id || 'local_' + Date.now();\n\n// ===== 4. 生成 external_id（业务主键） =====\nconst timestamp = Date.now();\nconst randomStr = Math.random().toString(36).substring(2, 9);\nconst external_id = `lead_${timestamp}_${randomStr}`;\n\n// ===== 5. 文本标准化（增强版） =====\nconst normalizedText = lead_text\n  .trim()\n  .toLowerCase()\n  .replace(/\\s+/g, ' ')\n  .replace(/\\s*([，。、！？,.])\\s*/g, '$1');\n\n// ===== 6. DJB2 hash 函数（稳定版） =====\nfunction stableHash(str) {\n  let hash = 5381;\n  for (let i = 0; i < str.length; i++) {\n    const char = str.charCodeAt(i);\n    hash = ((hash << 5) + hash) + char;\n    hash = hash >>> 0;\n  }\n  return hash.toString(36) + '_L' + str.length.toString(36);\n}\n\n// ===== 7. 生成幂等键 =====\nconst hash = stableHash(normalizedText);\nconst idempotency_key = `lead:${hash}`;\n\n// ===== 8. 返回所有字段 =====\nreturn {\n  json: {\n    is_valid: true,\n    run_id: run_id,\n    external_id: external_id,\n    idempotency_key: idempotency_key,\n    lead_text: lead_text.trim(),\n    normalized_text: normalizedText,\n    source: body.source || 'webhook',\n    received_at: new Date().toISOString()\n  }\n};"
      },
