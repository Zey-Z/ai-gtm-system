        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"text\": \"🚨 High-Quality Lead Alert!\\n\\nCompany: {{ $json.company }}\\nContact: {{ $json.contact_name }}\\nEmail: {{ $json.email }}\\nBudget: {{ $json.budget }}\\nUrgency: {{ $json.urgency }}\\nLead Score: {{ $json.score }}/100\\n\\n📋 HubSpot: {{ $json.hubspot_url }}\\n\\n🔍 Run ID: {{ $json.run_id }}\"\n}\n",
        "options": {}
      },
