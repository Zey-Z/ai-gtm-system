    {
      "parameters": {
        "jsCode": "// ============================================================\n// 节点 2.5: AI 输出验证（增强版）\n// 功能: 验证格式、字段类型、置信度范围、新增字段\n// ============================================================\n\n// 1. 获取 AI 提取的数据\nconst aiOutput = $input.item.json.output[0].content[0].text;\n\n// 2. 定义验证结果\nlet validationResult = {\n  is_valid: true,\n  errors: [],\n  warnings: [],\n  score_penalty: 0\n};\n\n// 3. 验证数据字段\nconst dataFields = {\n  company: aiOutput.company,\n  contact_name: aiOutput.contact_name,\n  email: aiOutput.email,\n  budget: aiOutput.budget,\n  urgency: aiOutput.urgency\n};\n\nlet extractedCount = 0;\nfor (const [field, value] of Object.entries(dataFields)) {\n  if (value && value !== null && value !== 'null' && String(value).trim() !== '') {\n    extractedCount++;\n  }\n}\nif (extractedCount < 2) {\n  validationResult.warnings.push(`Only ${extractedCount} fields extracted — low data quality`);\n  validationResult.score_penalty += 10;\n}\n\n// 4. Email 格式验证\nif (aiOutput.email && aiOutput.email !== null && aiOutput.email !== 'null') {\n  const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n  if (!emailRegex.test(String(aiOutput.email).trim())) {\n    validationResult.errors.push(`Invalid email format: ${aiOutput.email}`);\n    validationResult.score_penalty += 20;\n    validationResult.is_valid = false;\n  }\n}\n\n// 5. 数据类型检查\nfor (const [field, value] of Object.entries(dataFields)) {\n  if (value !== null && value !== undefined && typeof value !== 'string') {\n    validationResult.errors.push(`Field ${field}: expected string, got ${typeof value}`);\n    validationResult.score_penalty += 10;\n  }\n}\n\n// 6. Confidence 验证\nconst confidence = aiOutput.confidence;\nif (confidence && typeof confidence === 'object') {\n  for (const [field, value] of Object.entries(confidence)) {\n    if (typeof value !== 'number' || value < 0 || value > 1) {\n      validationResult.warnings.push(`Confidence for ${field} out of range: ${value}`);\n    }\n  }\n} else {\n  validationResult.warnings.push('Missing confidence scores from AI output');\n}\n\n// 7. Analysis summary 验证\nif (!aiOutput.analysis_summary || typeof aiOutput.analysis_summary !== 'string') {\n  validationResult.warnings.push('Missing analysis_summary from AI output');\n}\n\n// 8. 返回结果\nreturn {\n  json: {\n    ...aiOutput,\n    validation: validationResult\n  }\n};"
      },
