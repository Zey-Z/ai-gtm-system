    {
      "parameters": {
        "jsCode": "// ==============================================\n// 节点 3: 整理数据\n// 功能: 提取 AI 输出、计算评分、准备写入数据库\n// ==============================================\n\n// 1. 获取各个节点的数据\nconst run_id = $('1.5-Validate-Input-Generate-RunID').item.json.run_id;\nconst external_id = $('1.5-Validate-Input-Generate-RunID').item.json.external_id;\nconst lead_text = $('1.5-Validate-Input-Generate-RunID').item.json.lead_text;\n\n// 2. 获取 AI 提取的数据（已经过验证）\nconst aiData = $('2.5-Validate-AI-Output').item.json;\n\n// 3. 辅助函数：将 \"null\" 字符串和 null 统一处理为 null\nfunction toNullable(value) {\n  if (value === null || value === undefined || value === 'null' || value === '') {\n    return null;\n  }\n  return value;\n}\n\n// 4. SQL 单引号转义函数（防止 SQL 注入）\nfunction escapeSql(value) {\n  if (value === null || value === undefined) return null;\n  return String(value).replace(/'/g, \"''\");\n}\n\n// 5. 提取并标准化字段\nconst company = toNullable(aiData.company);\nconst contact_name = toNullable(aiData.contact_name);\nconst email = toNullable(aiData.email);\nconst budget = toNullable(aiData.budget);\nconst urgency = toNullable(aiData.urgency);\n\n// 6. 计算评分（基于规则）\nlet score = 50; // 基础分\n\n// 6.1 预算加分（最高 30 分）\nif (budget && budget !== 'null') {\n  if (budget.includes('万') || budget.includes('$') || budget.includes('美元')) {\n    score += 30;\n  }\n}\n\n// 6.2 紧急度加分（最高 20 分）\nif (urgency && urgency !== 'null') {\n  if (urgency.includes('天') || urgency.includes('周') || urgency.includes('紧急')) {\n    score += 20;\n  }\n}\n\n// 6.3 有邮箱加分（10 分）\nif (email && email !== 'null') {\n  score += 10;\n}\n\n// 6.4 应用验证扣罚（新增逻辑）\nconst validation = aiData.validation;\nif (validation && validation.score_penalty) {\n  score -= validation.score_penalty;\n  score = Math.max(score, 0);  // 确保不低于 0\n}\n\n// 6.5 确保评分在 0-100 之间\nscore = Math.min(Math.max(score, 0), 100);\n\n// 7. 返回整理后的数据（所有字符串字段经过 SQL 转义）\nreturn {\n  json: {\n    run_id: run_id,\n    external_id: external_id,\n    idempotency_key: $('1.5-Validate-Input-Generate-RunID').item.json.idempotency_key,\n    raw_text: escapeSql(lead_text),\n    company: escapeSql(company),\n    contact_name: escapeSql(contact_name),\n    email: escapeSql(email),\n    budget: escapeSql(budget),\n    urgency: escapeSql(urgency),\n    score: score,\n    status: 'new',\n    validation: validation\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
