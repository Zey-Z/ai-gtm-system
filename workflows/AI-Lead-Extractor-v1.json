    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO leads (\n    idempotency_key, external_id, run_id, raw_text,\n    company, contact_name, email, budget,\n    urgency, score, status,\n    created_at, updated_at\n)\nVALUES (\n    '{{ $json.idempotency_key }}',\n    '{{ $json.external_id }}',\n    '{{ $json.run_id }}',\n    '{{ $json.raw_text }}',\n    '{{ $json.company }}',\n    '{{ $json.contact_name }}',\n    '{{ $json.email }}',\n    '{{ $json.budget }}',\n    '{{ $json.urgency }}',\n    {{ $json.score }},\n    '{{ $json.status }}',\n    NOW(),\n    NOW()\n)\nON CONFLICT (idempotency_key) DO UPDATE SET\n    run_id = EXCLUDED.run_id,\n    updated_at = NOW(),\n    company = EXCLUDED.company,\n    contact_name = EXCLUDED.contact_name,\n    email = EXCLUDED.email,\n    budget = EXCLUDED.budget,\n    urgency = EXCLUDED.urgency,\n    score = EXCLUDED.score,\n    status = CASE\n        WHEN leads.status = 'processed' THEN 'processed'\n        ELSE EXCLUDED.status\n    END\nRETURNING id, idempotency_key, external_id, run_id, raw_text,\n          company, contact_name, email, budget, urgency, score, status,\n          created_at, updated_at, (xmax = 0) AS is_new_record;",
        "options": {}
      },
