    {
      "parameters": {
        "jsCode": "// ============================================================\n// 节点 2.5: 验证 AI 输出\n// 功能: 检查 AI 提取的数据是否符合预期格式\n// ============================================================\n\n// 1. 获取 AI 提取的数据（从正确的路径）\nconst aiOutput = $input.item.json.output[0].content[0].text;\n\n// 2. 定义验证结果\nlet validationResult = {\n  is_valid: true,\n  errors: [],\n  warnings: [],\n  score_penalty: 0\n};\n\n// 3. 验证必填字段（如果 AI 说提取到了，就必须有值）\nconst requiredFields = {\n  company: aiOutput.company,\n  contact_name: aiOutput.contact_name,\n  email: aiOutput.email,\n  budget: aiOutput.budget,\n  urgency: aiOutput.urgency\n};\n\n// 统计提取到的字段数\nlet extractedCount = 0;\nfor (const [field, value] of Object.entries(requiredFields)) {\n  if (value && value !== null && value !== 'null' && value.trim() !== '') {\n    extractedCount++;\n  }\n}\n\n// 如果提取字段太少，警告\nif (extractedCount < 2) {\n  validationResult.warnings.push(`AI 只提取到 ${extractedCount} 个字段，数据质量较低`);\n  validationResult.score_penalty += 10;\n}\n\n// 4. Email 格式验证\nif (aiOutput.email && aiOutput.email !== null && aiOutput.email !== 'null') {\n  const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n  if (!emailRegex.test(aiOutput.email.trim())) {\n    validationResult.errors.push(`Email 格式不正确: ${aiOutput.email}`);\n    validationResult.score_penalty += 20;\n    validationResult.is_valid = false;\n  }\n}\n\n// 5. 数据类型检查（确保返回的是字符串或 null）\nfor (const [field, value] of Object.entries(requiredFields)) {\n  if (value !== null && typeof value !== 'string') {\n    validationResult.errors.push(`字段 ${field} 类型错误，期望字符串，得到 ${typeof value}`);\n    validationResult.score_penalty += 10;\n  }\n}\n\n// 6. 返回结果（包含原始数据 + 验证结果）\nreturn {\n  json: {\n    ...aiOutput,  // 保留所有 AI 输出\n    validation: validationResult  // 添加验证结果\n  }\n};"
      },
