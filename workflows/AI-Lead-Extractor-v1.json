      "name": "7-Send-Slack-Notification"
    },
    {
      "parameters": {
        "jsCode": "// 从各个节点获取数据\nconst leadData = $('4-Write-to-Database').item.json;\nconst hubspotData = $('6-HubSpot Contact Upsert').item.json;\nconst runId = $('1.5-Validate-Input-Generate-RunID').item.json.run_id;\n\n// 从 HubSpot 输出中提取 contact ID\n// 根据你的输出结构，ID 在 properties.hs_object_id.value\nlet contactId;\nif (hubspotData.id) {\n  // 如果顶层有 id（标准格式）\n  contactId = hubspotData.id;\n} else if (hubspotData.properties && hubspotData.properties.hs_object_id) {\n  // 如果在 properties.hs_object_id.value\n  contactId = hubspotData.properties.hs_object_id.value;\n}\n\n// 构造 HubSpot URL\nconst hubspotUrl = `https://app.hubspot.com/contacts/YOUR_HUBSPOT_PORTAL_ID/contact/${contactId}`;\n\n// 返回准备好的数据\nreturn {\n  json: {\n    company: leadData.company || 'N/A',\n    contact_name: leadData.contact_name || 'N/A',\n    email: leadData.email || 'N/A',\n    budget: leadData.budget || 'N/A',\n    urgency: leadData.urgency || 'N/A',\n    score: leadData.score,\n    hubspot_url: hubspotUrl,\n    hubspot_contact_id: contactId,\n    run_id: runId\n  }\n};"
      },
