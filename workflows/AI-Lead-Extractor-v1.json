        "responses": {
          "values": [
            {
              "content": "=你是一个销售线索信息提取助手。\n\n输入是一段客户的咨询文本，请提取以下信息并以 JSON 格式返回：\n- company: 公司名称（如果没有提到，返回 null）\n- contact_name: 联系人姓名（如果没有提到，返回 null）\n- email: 邮箱地址（如果没有提到，返回 null）\n- budget: 预算范围（如果没有提到，返回 null）\n- urgency: 时间紧急度（如果没有提到，返回 null）\n\n输入文本：\n{{ $('1.5-Validate-Input-Generate-RunID').item.json.lead_text }}\n\n请只返回 JSON，不要有其他解释。"
            }
          ]
        },
        "builtInTools": {},
        "options": {
          "textFormat": {
            "textOptions": {
              "type": "json_object"
            }
          },
          "temperature": 0.1
        }
      },
      "type": "@n8n/n8n-nodes-langchain.openAi",
      "typeVersion": 2.1,
      "position": [
        1264,
