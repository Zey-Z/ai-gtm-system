# PostgreSQL 数据库配置
POSTGRES_USER=aigtm_user
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
POSTGRES_DB=aigtm

# n8n 加密密钥（用于保护 credentials）
# 生成方法：随便敲键盘生成一串至少 20 个字符的随机字符串
N8N_ENCRYPTION_KEY=CHANGE_ME_TO_RANDOM_STRING_AT_LEAST_20_CHARS

# AI API Key (used in n8n OpenAI node)
OPENAI_API_KEY=your_openai_api_key_here

# HubSpot Private App Token
# Create at: Settings > Integrations > Private Apps
# Required scopes: crm.objects.contacts.read, crm.objects.contacts.write
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here
HUBSPOT_PORTAL_ID=your_hubspot_portal_id

# Slack Incoming Webhook URL
# Create at: https://api.slack.com/apps > Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
